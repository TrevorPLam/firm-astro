---
import BaseLayout from "../layouts/BaseLayout.astro";
import Button from "../components/Button.astro";
---

<BaseLayout title="404 - Page Not Found">
  <section class="section min-h-[60vh] flex items-center justify-center">
    <div class="container-custom">
      <div class="max-w-2xl mx-auto text-center">
        <!-- Glitch 404 -->
        <div class="relative mb-8">
          <h1
            class="text-[150px] md:text-[200px] font-display font-bold text-electric-500/20 select-none"
          >
            404
          </h1>
          <div class="absolute inset-0 flex items-center justify-center">
            <h1
              class="text-6xl md:text-8xl font-display font-bold text-electric-400 neon-text animate-glitch"
            >
              404
            </h1>
          </div>
        </div>

        <h2 class="text-2xl md:text-3xl font-display font-bold text-white mb-4 dark:text-white text-light-900">Page Not Found</h2>
        <p class="text-gray-400 mb-8 max-w-md mx-auto dark:text-gray-400 text-light-700">
          The page you're looking for doesn't exist or has been moved. Let's get you back on track.
        </p>

        <!-- Search -->
        <div class="max-w-md mx-auto mb-8">
          <div class="relative">
            <svg
              class="absolute left-4 top-1/2 -translate-y-1/2 w-5 h-5 text-gray-500"
              fill="none"
              stroke="currentColor"
              viewBox="0 0 24 24"
            >
              <path
                stroke-linecap="round"
                stroke-linejoin="round"
                stroke-width="2"
                d="M21 21l-6-6m2-5a7 7 0 11-14 0 7 7 0 0114 0z"></path>
            </svg>
            <input
              type="text"
              placeholder="Search our site..."
              class="w-full pl-12 pr-4 py-3 bg-white/5 border border-white/10 rounded-lg text-white placeholder-gray-500 focus:outline-none focus:border-electric-500 focus:ring-1 focus:ring-electric-500 transition-colors"
            />
          </div>
        </div>

        <!-- Quick Links -->
        <div class="flex flex-col sm:flex-row gap-4 justify-center mb-12">
          <Button href="/" variant="primary"> Go Home </Button>
          <Button href="/services" variant="secondary"> View Services </Button>
        </div>

        <!-- Popular Pages -->
        <div class="glass-card p-6">
          <h3 class="font-display font-semibold text-white mb-4 dark:text-white text-light-900">Popular Pages</h3>
          <div class="grid grid-cols-2 md:grid-cols-4 gap-4">
            <a
              href="/services"
              class="text-sm text-gray-400 hover:text-electric-400 transition-colors dark:text-gray-400 text-light-700">Services</a
            >
            <a href="/work" class="text-sm text-gray-400 hover:text-electric-400 transition-colors dark:text-gray-400 text-light-700"
              >Case Studies</a
            >
            <a href="/about" class="text-sm text-gray-400 hover:text-electric-400 transition-colors dark:text-gray-400 text-light-700"
              >About Us</a
            >
            <a
              href="/contact"
              class="text-sm text-gray-400 hover:text-electric-400 transition-colors dark:text-gray-400 text-light-700">Contact</a
            >
            <a
              href="/pricing"
              class="text-sm text-gray-400 hover:text-electric-400 transition-colors dark:text-gray-400 text-light-700">Pricing</a
            >
            <a href="/blog" class="text-sm text-gray-400 hover:text-electric-400 transition-colors dark:text-gray-400 text-light-700"
              >Blog</a
            >
            <a href="/faq" class="text-sm text-gray-400 hover:text-electric-400 transition-colors dark:text-gray-400 text-light-700"
              >FAQ</a
            >
            <a href="/team" class="text-sm text-gray-500 hover:text-electric-400 transition-colors dark:text-gray-500 text-light-700"
              >Team</a
            >
          </div>
        </div>
      </div>
    </div>
  </section>
</BaseLayout>

<style>
  @keyframes glitch {
    0%,
    100% {
      text-shadow:
        0 0 10px theme("colors.electric.500"),
        0 0 20px theme("colors.electric.500"),
        0 0 40px theme("colors.electric.500");
    }
    25% {
      text-shadow:
        -2px 0 #ff00ff,
        2px 0 #00ffff,
        0 0 20px theme("colors.electric.500");
      transform: translate(-2px, 1px);
    }
    50% {
      text-shadow:
        2px 0 #ff00ff,
        -2px 0 #00ffff,
        0 0 20px theme("colors.electric.500");
      transform: translate(2px, -1px);
    }
    75% {
      text-shadow:
        -1px 0 #ff00ff,
        1px 0 #00ffff,
        0 0 20px theme("colors.electric.500");
      transform: translate(-1px, 2px);
    }
  }

  .animate-glitch {
    animation: glitch 0.5s ease-in-out infinite;
  }
</style>
