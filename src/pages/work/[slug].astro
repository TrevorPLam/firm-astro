---
import BaseLayout from '../../layouts/BaseLayout.astro';
import Button from '../../components/Button.astro';
import { getCollection, type CollectionEntry } from 'astro:content';

export async function getStaticPaths() {
  const caseStudies = await getCollection('caseStudies');
  return caseStudies.map((cs) => ({
    params: { slug: cs.slug },
    props: { caseStudy: cs },
  }));
}

interface Props {
  caseStudy: CollectionEntry<'caseStudies'>;
}

const { caseStudy } = Astro.props;
const { title, client, industry, services, challenge, solution, results, testimonial, image, publishedAt } = caseStudy.data;

const formattedDate = publishedAt.toLocaleDateString('en-US', {
  year: 'numeric',
  month: 'long',
  day: 'numeric',
});
---

<BaseLayout title={`${title} | Case Study`} description={`${challenge} - See how we helped ${client} achieve ${results[0]?.value || 'remarkable results'}.`}>
  <!-- Hero -->
  <section class="section relative overflow-hidden">
    <div class="absolute inset-0 radial-glow" />
    <div class="container-custom relative">
      <div class="max-w-4xl">
        <div class="flex items-center gap-3 mb-6">
          <span class="text-sm text-electric-400 font-medium uppercase tracking-wider">{industry}</span>
          <span class="text-gray-600">·</span>
          <time class="text-sm text-gray-500">{formattedDate}</time>
        </div>
        <h1 class="text-4xl md:text-5xl lg:text-6xl font-display font-bold mb-6">
          {title}
        </h1>
        <p class="text-xl text-gray-400 mb-4">{client}</p>
        
        <div class="flex flex-wrap gap-2 mb-8">
          {services.map((service) => (
            <span class="px-3 py-1 text-sm bg-electric-500/20 text-electric-400 rounded-full">
              {service}
            </span>
          ))}
        </div>
      </div>
    </div>
  </section>

  {image && (
    <section class="section pt-0">
      <div class="container-custom">
        <div class="aspect-video max-w-5xl mx-auto rounded-2xl overflow-hidden glass-card">
          <img src={image} alt={title} class="w-full h-full object-cover" loading="eager" />
        </div>
      </div>
    </section>
  )}

  <!-- Results Overview -->
  <section class="section bg-dark-800/50">
    <div class="container-custom">
      <h2 class="font-display text-2xl font-bold text-white mb-8 text-center">
        Key <span class="text-electric-400">Results</span>
      </h2>
      <div class="grid grid-cols-2 md:grid-cols-4 gap-6 max-w-4xl mx-auto">
        {results.map((result) => (
          <div class="glass-card p-6 text-center">
            <div class="text-3xl md:text-4xl font-display font-bold text-electric-400 neon-text mb-2">
              {result.value}
            </div>
            <div class="text-sm text-gray-400">{result.metric}</div>
            {result.improvement && (
              <div class="text-xs text-green-400 mt-2">+{result.improvement}</div>
            )}
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- Challenge -->
  <section class="section">
    <div class="container-custom">
      <div class="max-w-3xl mx-auto">
        <h2 class="font-display text-2xl font-bold text-white mb-6">
          The <span class="text-electric-400">Challenge</span>
        </h2>
        <div class="glass-card p-8">
          <p class="text-gray-300 leading-relaxed">{challenge}</p>
        </div>
      </div>
    </div>
  </section>

  <!-- Solution -->
  <section class="section bg-dark-800/50">
    <div class="container-custom">
      <div class="max-w-3xl mx-auto">
        <h2 class="font-display text-2xl font-bold text-white mb-6">
          Our <span class="text-electric-400">Approach</span>
        </h2>
        <div class="glass-card p-8">
          <p class="text-gray-300 leading-relaxed">{solution}</p>
        </div>
      </div>
    </div>
  </section>

  <!-- Testimonial -->
  {testimonial && (
    <section class="section">
      <div class="container-custom">
        <div class="max-w-3xl mx-auto">
          <div class="glass-card p-8 md:p-12 relative">
            <svg class="absolute top-6 left-6 w-12 h-12 text-electric-500/20" fill="currentColor" viewBox="0 0 24 24">
              <path d="M14.017 21v-7.391c0-5.704 3.731-9.57 8.983-10.609l.995 2.151c-2.432.917-3.995 3.638-3.995 5.849h4v10h-9.983zm-14.017 0v-7.391c0-5.704 3.748-9.57 9-10.609l.996 2.151c-2.433.917-3.996 3.638-3.996 5.849h3.983v10h-9.983z" />
            </svg>
            <blockquote class="relative z-10">
              <p class="text-xl md:text-2xl text-white font-display leading-relaxed mb-6">
                "{testimonial.quote}"
              </p>
              <footer>
                <cite class="not-italic">
                  <span class="text-electric-400 font-semibold">{testimonial.author}</span>
                  <span class="text-gray-400 block text-sm mt-1">{testimonial.role}</span>
                </cite>
              </footer>
            </blockquote>
          </div>
        </div>
      </div>
    </section>
  )}

  <!-- CTA -->
  <section class="section">
    <div class="container-custom">
      <div class="glass-card p-12 text-center relative overflow-hidden">
        <div class="absolute inset-0 radial-glow" />
        <div class="relative">
          <h2 class="text-2xl md:text-3xl font-display font-bold mb-4">
            Ready to Achieve Similar Results?
          </h2>
          <p class="text-gray-400 max-w-xl mx-auto mb-8">
            Let's discuss how we can help your business achieve extraordinary growth.
          </p>
          <Button href="/contact" variant="primary" size="lg">
            Start Your Project
          </Button>
        </div>
      </div>
    </div>
  </section>
</BaseLayout>
