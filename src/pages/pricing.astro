---
import BaseLayout from '../layouts/BaseLayout.astro';
import PricingCard from '../components/PricingCard.astro';
import FAQAccordion from '../components/FAQAccordion';

const packages = [
  {
    name: 'Startup',
    price: '$2,500',
    description: 'Perfect for early-stage companies looking to establish their digital presence.',
    features: [
      'SEO Foundation Package',
      'Basic Paid Media Setup',
      'Monthly Content (4 posts)',
      'Email Automation Setup',
      'Monthly Reporting',
      'Dedicated Account Manager',
    ],
    highlighted: false,
    ctaText: 'Get Started',
  },
  {
    name: 'Scale-Up',
    price: '$7,500',
    description: 'Ideal for growing companies ready to accelerate their marketing efforts.',
    features: [
      'Advanced SEO Strategy',
      'Multi-Channel Paid Media',
      'Content Marketing (8 posts/mo)',
      'Advanced Email Automation',
      'Conversion Rate Optimization',
      'Weekly Reporting & Strategy Calls',
      'Priority Support',
    ],
    highlighted: true,
    ctaText: 'Most Popular',
  },
  {
    name: 'Enterprise',
    price: 'Custom',
    description: 'Comprehensive solutions for established brands with complex needs.',
    features: [
      'Full-Service Marketing',
      'Custom Strategy Development',
      'Unlimited Content Production',
      'Marketing Automation Suite',
      'Advanced Analytics & BI',
      'Dedicated Team',
      '24/7 Priority Support',
      'Quarterly Business Reviews',
    ],
    highlighted: false,
    ctaText: 'Contact Us',
  },
];

const faqs = [
  {
    question: 'Are there any setup fees?',
    answer: 'We charge a one-time setup fee of $500 for Startup and Scale-Up packages to cover initial strategy development and account configuration. Enterprise clients have custom arrangements.',
  },
  {
    question: 'Can I switch between packages?',
    answer: 'Yes, you can upgrade or downgrade your package at any time. Changes take effect at the start of the next billing cycle. We\'ll work with you to ensure a smooth transition.',
  },
  {
    question: 'What\'s the minimum contract length?',
    answer: 'We offer month-to-month flexibility on all packages. However, we recommend a minimum 3-month commitment to see meaningful results from marketing efforts.',
  },
  {
    question: 'Do you offer discounts for annual commitments?',
    answer: 'Yes! We offer 15% off for 6-month commitments and 25% off for annual commitments. This reflects the value of long-term partnerships.',
  },
  {
    question: 'What\'s not included in the package price?',
    answer: 'Advertising spend (Google Ads, Meta Ads, etc.) is separate and paid directly to platforms. Premium tools or software licenses beyond our standard stack may incur additional costs.',
  },
  {
    question: 'How do I know which package is right for me?',
    answer: 'Schedule a free consultation and we\'ll assess your needs, goals, and budget to recommend the best fit. We\'ll never upsell you on services you don\'t need.',
  },
];
---

<BaseLayout title="Pricing" description="Transparent pricing for digital marketing services. Choose from Startup, Scale-Up, or Enterprise packages designed for your growth stage.">
  <!-- Hero -->
  <section class="section relative overflow-hidden">
    <div class="absolute inset-0 radial-glow" />
    <div class="container-custom relative">
      <div class="text-center max-w-3xl mx-auto">
        <h1 class="text-4xl md:text-5xl lg:text-6xl font-display font-bold mb-6">
          Simple, Transparent <span class="text-electric-400 neon-text">Pricing</span>
        </h1>
        <p class="text-lg text-gray-400 leading-relaxed">
          Choose the package that fits your growth stage. All plans include dedicated support and monthly strategy sessions.
        </p>
      </div>
    </div>
  </section>

  <!-- Pricing Cards -->
  <section class="section">
    <div class="container-custom">
      <div class="grid md:grid-cols-3 gap-6 lg:gap-8 max-w-6xl mx-auto">
        {packages.map((pkg) => (
          <PricingCard {...pkg} />
        ))}
      </div>
    </div>
  </section>

  <!-- Custom Solutions -->
  <section class="section bg-dark-800/50">
    <div class="container-custom">
      <div class="glass-card p-12 text-center relative overflow-hidden">
        <div class="absolute inset-0 radial-glow" />
        <div class="relative">
          <h2 class="text-2xl md:text-3xl font-display font-bold mb-4">
            Need a Custom Solution?
          </h2>
          <p class="text-gray-400 max-w-xl mx-auto mb-8">
            We understand that every business is unique. Let's create a tailored package that fits your specific needs and budget.
          </p>
          <a href="/contact" class="btn-primary inline-flex items-center justify-center px-8 py-4 text-base">
            Request Custom Quote
          </a>
        </div>
      </div>
    </div>
  </section>

  <!-- FAQ -->
  <section class="section">
    <div class="container-custom">
      <div class="max-w-3xl mx-auto">
        <h2 class="font-display text-2xl font-bold text-white mb-8 text-center">
          Pricing <span class="text-electric-400">FAQ</span>
        </h2>
        <FAQAccordion items={faqs} client:load />
      </div>
    </div>
  </section>
</BaseLayout>
