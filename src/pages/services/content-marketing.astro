---
import BaseLayout from '../../layouts/BaseLayout.astro';
import Button from '../../components/Button.astro';
import ProcessStep from '../../components/ProcessStep.astro';

const benefits = [
  'Build brand authority and trust',
  'Drive organic traffic growth',
  'Nurture leads through the funnel',
  'Support SEO and social media efforts',
  'Create reusable marketing assets',
  'Establish thought leadership',
];

const contentTypes = [
  { name: 'Blog Posts', desc: 'SEO-optimized articles' },
  { name: 'Whitepapers', desc: 'In-depth research' },
  { name: 'Case Studies', desc: 'Success stories' },
  { name: 'Video Content', desc: 'Engaging visuals' },
  { name: 'Infographics', desc: 'Data visualization' },
  { name: 'Social Content', desc: 'Platform-specific' },
];

const processSteps = [
  { number: '01', title: 'Content Strategy', description: 'Define content pillars, topics, and distribution channels aligned with business goals.' },
  { number: '02', title: 'Content Creation', description: 'Produce high-quality, engaging content optimized for search and conversion.' },
  { number: '03', title: 'Distribution', description: 'Strategic promotion across owned, earned, and paid channels.' },
  { number: '04', title: 'Analysis & Iteration', description: 'Track performance and refine strategy based on data insights.' },
];
---

<BaseLayout title="Content Marketing Services" description="Build authority and engage your audience with strategic content marketing. Blog posts, whitepapers, video content, and distribution strategies.">
  <section class="section relative overflow-hidden">
    <div class="absolute inset-0 radial-glow" />
    <div class="container-custom relative">
      <div class="grid lg:grid-cols-2 gap-12 items-center">
        <div>
          <div class="inline-flex items-center gap-2 px-4 py-2 rounded-full bg-electric-500/10 border border-electric-500/20 mb-6">
            <span class="text-sm text-electric-400 font-medium">Content Strategy</span>
          </div>
          <h1 class="text-4xl md:text-5xl font-display font-bold mb-6">
            <span class="text-electric-400 neon-text">Content Marketing</span> Services
          </h1>
          <p class="text-lg text-gray-400 leading-relaxed mb-8">
            Build authority and engage your audience with strategic content that converts. From blog posts to video content, we create assets that drive results.
          </p>
          <div class="flex flex-col sm:flex-row gap-4">
            <Button href="/contact" variant="primary">Get Started</Button>
            <Button href="/work" variant="secondary">View Case Studies</Button>
          </div>
        </div>
        
        <div class="glass-card p-8">
          <h3 class="font-display text-xl font-semibold text-white mb-6">Content Types</h3>
          <div class="grid grid-cols-2 gap-4">
            {contentTypes.map((type) => (
              <div class="p-4 rounded-lg bg-white/5 hover:bg-electric-500/10 transition-colors">
                <h4 class="font-semibold text-white">{type.name}</h4>
                <p class="text-sm text-gray-400">{type.desc}</p>
              </div>
            ))}
          </div>
        </div>
      </div>
    </div>
  </section>

  <section class="section bg-dark-800/50">
    <div class="container-custom">
      <div class="grid lg:grid-cols-2 gap-12 items-center">
        <div>
          <h2 class="text-3xl md:text-4xl font-display font-bold mb-6">Benefits of <span class="text-electric-400">Content Marketing</span></h2>
          <ul class="space-y-4">
            {benefits.map((benefit) => (
              <li class="flex items-start gap-3">
                <svg class="w-5 h-5 text-electric-400 flex-shrink-0 mt-0.5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7" />
                </svg>
                <span class="text-gray-300">{benefit}</span>
              </li>
            ))}
          </ul>
        </div>
        
        <div class="glass-card p-8">
          <h3 class="font-display text-xl font-semibold text-white mb-6">Quick Stats</h3>
          <div class="grid grid-cols-2 gap-6">
            <div class="text-center">
              <div class="text-3xl font-display font-bold text-electric-400 neon-text">3x</div>
              <div class="text-sm text-gray-500 mt-1">More Leads</div>
            </div>
            <div class="text-center">
              <div class="text-3xl font-display font-bold text-electric-400 neon-text">72%</div>
              <div class="text-sm text-gray-500 mt-1">Conversion Lift</div>
            </div>
            <div class="text-center">
              <div class="text-3xl font-display font-bold text-electric-400 neon-text">500+</div>
              <div class="text-sm text-gray-500 mt-1">Articles Published</div>
            </div>
            <div class="text-center">
              <div class="text-3xl font-display font-bold text-electric-400 neon-text">2.5M</div>
              <div class="text-sm text-gray-500 mt-1">Words Written</div>
            </div>
          </div>
        </div>
      </div>
    </div>
  </section>

  <section class="section">
    <div class="container-custom">
      <div class="text-center mb-12">
        <h2 class="text-3xl md:text-4xl font-display font-bold mb-4">Our Content <span class="text-electric-400">Process</span></h2>
      </div>
      <div class="max-w-2xl mx-auto">
        {processSteps.map((step, index) => (
          <ProcessStep number={step.number} title={step.title} description={step.description} isLast={index === processSteps.length - 1} />
        ))}
      </div>
    </div>
  </section>

  <section class="section">
    <div class="container-custom">
      <div class="glass-card p-12 text-center relative overflow-hidden">
        <div class="absolute inset-0 radial-glow" />
        <div class="relative">
          <h2 class="text-2xl md:text-3xl font-display font-bold mb-4">Ready to Build Your Content Engine?</h2>
          <p class="text-gray-400 max-w-xl mx-auto mb-8">Let's discuss how content marketing can establish your brand as an industry leader.</p>
          <Button href="/contact" variant="primary" size="lg">Start Your Content Strategy</Button>
        </div>
      </div>
    </div>
  </section>
</BaseLayout>
