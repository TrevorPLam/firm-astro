---
import BaseLayout from "../layouts/BaseLayout.astro";
import TeamCard from "../components/TeamCard.astro";
import { team } from "../data/team";
---

<BaseLayout
  title="Our Team"
  description="Meet the expert team behind Your Dedicated Marketer. Marketing professionals, data scientists, and creative strategists."
>
  <!-- Hero -->
  <section class="section relative overflow-hidden">
    <div class="absolute inset-0 radial-glow"></div>
    <div class="container-custom relative">
      <div class="max-w-3xl">
        <h1 class="text-4xl md:text-5xl lg:text-6xl font-display font-bold mb-6">
          Our <span class="text-electric-400 neon-text">Team</span>
        </h1>
        <p class="text-lg text-gray-400 leading-relaxed">
          Meet the experts behind your growth. Our team combines decades of experience with
          cutting-edge AI expertise to deliver exceptional results.
        </p>
      </div>
    </div>
  </section>

  <!-- Team Grid -->
  <section class="section">
    <div class="container-custom">
      <div class="grid md:grid-cols-2 lg:grid-cols-4 gap-6">
        {team.map((member) => <TeamCard {...member} />)}
      </div>
    </div>
  </section>

  <!-- Join Us -->
  <section class="section bg-dark-800/50">
    <div class="container-custom">
      <div class="glass-card p-12 text-center relative overflow-hidden">
        <div class="absolute inset-0 radial-glow"></div>
        <div class="relative">
          <h2 class="text-2xl md:text-3xl font-display font-bold mb-4">Join Our Team</h2>
          <p class="text-gray-400 max-w-xl mx-auto mb-8">
            We're always looking for talented individuals who share our passion for data-driven
            marketing. Check out our open positions.
          </p>
          <a
            href="/careers"
            class="btn-secondary inline-flex items-center justify-center px-8 py-4 text-base"
          >
            View Open Positions
          </a>
        </div>
      </div>
    </div>
  </section>
</BaseLayout>
