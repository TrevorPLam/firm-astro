---
import BaseLayout from "../../layouts/BaseLayout.astro";
import { getCollection } from "astro:content";

const blogPosts = await getCollection("blog", ({ data }) => {
  return data.pubDate;
});

const sortedPosts = blogPosts.sort((a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf());
---

<BaseLayout
  title="Blog"
  description="Expert insights, strategies, and tips for digital marketing success. Stay updated with the latest trends in SEO, paid media, content marketing, and more."
>
  <!-- Hero -->
  <section class="section relative overflow-hidden">
    <div class="absolute inset-0 radial-glow"></div>
    <div class="container-custom relative">
      <div class="max-w-3xl">
        <h1 class="text-4xl md:text-5xl lg:text-6xl font-display font-bold mb-6">
          Our <span class="text-electric-400 neon-text">Blog</span>
        </h1>
        <p class="text-lg text-gray-400 leading-relaxed">
          Expert insights, strategies, and tips for digital marketing success. Stay updated with the
          latest trends in SEO, paid media, content marketing, and more.
        </p>
      </div>
    </div>
  </section>

  <!-- Blog Grid -->
  <section class="section">
    <div class="container-custom">
      {
        sortedPosts.length > 0 ? (
          <>
            <div class="grid md:grid-cols-2 lg:grid-cols-3 gap-6">
              {sortedPosts.map((post) => (
                <a href={`/blog/${post.slug}`} class="glass-card overflow-hidden card-hover group">
                  {post.data.image && (
                    <div class="aspect-video bg-white/5 overflow-hidden">
                      <img
                        src={post.data.image}
                        alt={post.data.imageAlt || post.data.title}
                        class="w-full h-full object-cover group-hover:scale-105 transition-transform duration-500"
                        loading="lazy"
                      />
                    </div>
                  )}
                  <div class="p-6">
                    <div class="flex items-center gap-3 mb-3">
                      <span class="text-xs text-electric-400 font-medium">
                        {post.data.category}
                      </span>
                      <time class="text-xs text-gray-500">
                        {post.data.pubDate.toLocaleDateString("en-US", {
                          month: "short",
                          day: "numeric",
                          year: "numeric",
                        })}
                      </time>
                    </div>
                    <h2 class="font-display text-lg font-semibold text-white mb-3 group-hover:text-electric-400 transition-colors">
                      {post.data.title}
                    </h2>
                    <p class="text-gray-400 text-sm line-clamp-2 mb-4">{post.data.description}</p>
                    <div class="flex items-center gap-2 text-sm text-gray-500">
                      <span>{post.data.author}</span>
                      {post.data.readingTime && (
                        <>
                          <span>·</span>
                          <span>{post.data.readingTime}</span>
                        </>
                      )}
                    </div>
                  </div>
                </a>
              ))}
            </div>
          </>
        ) : (
          <div class="glass-card p-12 text-center">
            <div class="w-16 h-16 rounded-full bg-electric-500/20 flex items-center justify-center mx-auto mb-6">
              <svg
                class="w-8 h-8 text-electric-400"
                fill="none"
                stroke="currentColor"
                viewBox="0 0 24 24"
              >
                <path
                  stroke-linecap="round"
                  stroke-linejoin="round"
                  stroke-width="2"
                  d="M19 20H5a2 2 0 01-2-2V6a2 2 0 012-2h10a2 2 0 012 2v1m2 13a2 2 0 01-2-2V7m2 13a2 2 0 002-2V9a2 2 0 00-2-2h-2m-4-3H9M7 16h6M7 8h6v4H7V8z"
                />
              </svg>
            </div>
            <h3 class="font-display text-xl font-semibold text-white mb-2">
              Blog Posts Coming Soon
            </h3>
            <p class="text-gray-400 max-w-md mx-auto">
              We're preparing expert insights and marketing strategies. Check back soon for valuable
              content.
            </p>
          </div>
        )
      }
    </div>
  </section>
</BaseLayout>
