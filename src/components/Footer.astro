---
import { FOOTER_LINKS, SITE_NAME } from "../constants";

const socialLinks = [
  { href: "https://instagram.com/YourDedicatedMarketer", label: "Instagram", icon: "instagram" },
  { href: "https://threads.net/YourDedicatedMarketer", label: "Threads", icon: "threads" },
  { href: "https://youtube.com/YourDedicatedMarketer", label: "YouTube", icon: "youtube" },
];
---

<footer class="bg-light-100 dark:bg-dark-800 border-t border-light-200 dark:border-white/5">
  <div class="container-custom py-16">
    <div class="grid grid-cols-2 md:grid-cols-4 lg:grid-cols-5 gap-8 lg:gap-12">
      <!-- Brand Column -->
      <div class="col-span-2 md:col-span-4 lg:col-span-1">
        <a href="/" class="flex items-center gap-2 mb-4 focus-ring">
          <div class="w-10 h-10 rounded-lg bg-electric-500 flex items-center justify-center">
            <span class="text-white font-display font-bold text-xl">Y</span>
          </div>
          <span class="font-display font-bold text-lg text-light-900 dark:text-white">
            Your Dedicated <span class="text-electric-500">Marketer</span>
          </span>
        </a>
        <p class="text-light-600 dark:text-gray-400 text-sm mb-6">
          AI-powered growth strategies for modern brands. Transform your digital presence with
          data-driven marketing.
        </p>
        <div class="flex gap-4">
          {
            socialLinks.map((social) => (
              <a
                href={social.href}
                target="_blank"
                rel="noopener noreferrer"
                class="w-10 h-10 rounded-lg bg-light-200 dark:bg-white/5 flex items-center justify-center text-light-600 dark:text-gray-400 hover:text-electric-400 hover:bg-electric-500/10 transition-colors focus-ring"
                aria-label={social.label}
              >
                {social.icon === "instagram" && (
                  <svg class="w-5 h-5" fill="currentColor" viewBox="0 0 24 24">
                    <path d="M12 2.163c3.204 0 3.584.012 4.85.07 3.252.148 4.771 1.691 4.919 4.919.058 1.265.069 1.645.069 4.849 0 3.205-.012 3.584-.069 4.849-.149 3.225-1.664 4.771-4.919 4.919-1.266.058-1.644.07-4.85.07-3.204 0-3.584-.012-4.849-.07-3.26-.149-4.771-1.699-4.919-4.92-.058-1.265-.07-1.644-.07-4.849 0-3.204.013-3.583.07-4.849.149-3.227 1.664-4.771 4.919-4.919 1.266-.057 1.645-.069 4.849-.069zM12 0C8.741 0 8.333.014 7.053.072 2.695.272.273 2.69.073 7.052.014 8.333 0 8.741 0 12c0 3.259.014 3.668.072 4.948.2 4.358 2.618 6.78 6.98 6.98C8.333 23.986 8.741 24 12 24c3.259 0 3.668-.014 4.948-.072 4.354-.2 6.782-2.618 6.979-6.98.059-1.28.073-1.689.073-4.948 0-3.259-.014-3.667-.072-4.947-.196-4.354-2.617-6.78-6.979-6.98C15.668.014 15.259 0 12 0zm0 5.838a6.162 6.162 0 100 12.324 6.162 6.162 0 000-12.324zM12 16a4 4 0 110-8 4 4 0 010 8zm6.406-11.845a1.44 1.44 0 100 2.881 1.44 1.44 0 000-2.881z" />
                  </svg>
                )}
                {social.icon === "threads" && (
                  <svg class="w-5 h-5" fill="currentColor" viewBox="0 0 24 24">
                    <path d="M12 2C6.48 2 2 6.48 2 12s4.48 10 10 10 10-4.48 10-10S17.52 2 12 2zm0 18c-4.41 0-8-3.59-8-8s3.59-8 8-8 8 3.59 8 8-3.59 8-8 8zm-2-5.5c0 1.38 1.12 2.5 2.5 2.5s2.5-1.12 2.5-2.5-1.12-2.5-2.5-2.5-2.5 1.12-2.5 2.5z" />
                  </svg>
                )}
                {social.icon === "youtube" && (
                  <svg class="w-5 h-5" fill="currentColor" viewBox="0 0 24 24">
                    <path d="M23.498 6.186a3.016 3.016 0 0 0-2.122-2.136C19.505 3.545 12 3.545 12 3.545s-7.505 0-9.377.505A3.017 3.017 0 0 0 .502 6.186C0 8.07 0 12 0 12s0 3.93.502 5.814a3.016 3.016 0 0 0 2.122 2.136c1.871.505 9.376.505 9.376.505s7.505 0 9.377-.505a3.015 3.015 0 0 0 2.122-2.136C24 15.93 24 12 24 12s0-3.93-.502-5.814zM9.545 15.568V8.432L15.818 12l-6.273 3.568z" />
                  </svg>
                )}
              </a>
            ))
          }
        </div>
      </div>

      <!-- Services -->
      <div>
        <h4 class="font-display font-semibold text-light-900 dark:text-white mb-4">Services</h4>
        <ul class="space-y-2">
          {
            FOOTER_LINKS.services.map((link) => (
              <li>
                <a
                  href={link.href}
                  class="text-sm text-light-600 dark:text-gray-400 hover:text-electric-400 transition-colors focus-ring"
                >
                  {link.label}
                </a>
              </li>
            ))
          }
        </ul>
      </div>

      <!-- Company -->
      <div>
        <h4 class="font-display font-semibold text-light-900 dark:text-white mb-4">Company</h4>
        <ul class="space-y-2">
          {
            FOOTER_LINKS.company.map((link) => (
              <li>
                <a
                  href={link.href}
                  class="text-sm text-light-600 dark:text-gray-400 hover:text-electric-400 transition-colors focus-ring"
                >
                  {link.label}
                </a>
              </li>
            ))
          }
        </ul>
      </div>

      <!-- Resources -->
      <div>
        <h4 class="font-display font-semibold text-light-900 dark:text-white mb-4">Resources</h4>
        <ul class="space-y-2">
          {
            FOOTER_LINKS.resources.map((link) => (
              <li>
                <a
                  href={link.href}
                  class="text-sm text-light-600 dark:text-gray-400 hover:text-electric-400 transition-colors focus-ring"
                >
                  {link.label}
                </a>
              </li>
            ))
          }
        </ul>
      </div>

      <!-- Legal -->
      <div>
        <h4 class="font-display font-semibold text-light-900 dark:text-white mb-4">Legal</h4>
        <ul class="space-y-2">
          {
            FOOTER_LINKS.legal.map((link) => (
              <li>
                <a
                  href={link.href}
                  class="text-sm text-light-600 dark:text-gray-400 hover:text-electric-400 transition-colors focus-ring"
                >
                  {link.label}
                </a>
              </li>
            ))
          }
        </ul>
      </div>
    </div>

    <!-- Bottom Bar -->
    <div
      class="mt-12 pt-8 border-t border-light-200 dark:border-white/5 flex flex-col md:flex-row justify-between items-center gap-4"
    >
      <p class="text-sm text-light-700 dark:text-gray-400">
        © {new Date().getFullYear()}
        {SITE_NAME}. All rights reserved.
      </p>
      <p class="text-sm text-light-700 dark:text-gray-400">
        Built with <span class="text-electric-500">Astro</span> & <span class="text-electric-500"
          >Tailwind CSS</span
        >
      </p>
    </div>
  </div>
</footer>
