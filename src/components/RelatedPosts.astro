---
import type { CollectionEntry } from "astro:content";
import { getCollection } from "astro:content";

interface Props {
  currentPost: CollectionEntry<"blog">;
  limit?: number;
}

const { currentPost, limit = 3 } = Astro.props;

// Get all blog posts and filter out current post
const allPosts = await getCollection("blog");
const relatedPosts = allPosts
  .filter((post) => post.id !== currentPost.id)
  .filter((post) => {
    // Prioritize posts with same category or tags
    const sameCategory = post.data.category === currentPost.data.category;
    const sharedTags = post.data.tags.some((tag) => currentPost.data.tags.includes(tag));
    return sameCategory || sharedTags;
  })
  .slice(0, limit);

// If not enough related posts, fill with recent posts
const recentPosts = allPosts
  .filter((post) => post.id !== currentPost.id && !relatedPosts.includes(post))
  .sort((a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf())
  .slice(0, limit - relatedPosts.length);

const postsToShow = [...relatedPosts, ...recentPosts];
---

<div class="container-custom">
  <h2 class="font-display text-2xl md:text-3xl font-bold text-white mb-8">
    Related <span class="text-electric-400">Articles</span>
  </h2>

  <div class="grid md:grid-cols-2 lg:grid-cols-3 gap-6">
    {
      postsToShow.map((post) => (
        <a href={`/blog/${post.slug}`} class="glass-card p-6 card-hover group">
          {post.data.image && (
            <div class="aspect-video rounded-lg overflow-hidden mb-4 bg-white/5">
              <img
                src={post.data.image}
                alt={post.data.imageAlt || post.data.title}
                class="w-full h-full object-cover group-hover:scale-105 transition-transform duration-300"
                loading="lazy"
              />
            </div>
          )}
          <span class="text-xs text-electric-400 font-medium">{post.data.category}</span>
          <h3 class="font-display font-semibold text-white mt-2 mb-3 group-hover:text-electric-400 transition-colors">
            {post.data.title}
          </h3>
          <p class="text-gray-400 text-sm line-clamp-2">{post.data.description}</p>
          <time class="text-xs text-gray-500 mt-4 block">
            {post.data.pubDate.toLocaleDateString("en-US", {
              year: "numeric",
              month: "short",
              day: "numeric",
            })}
          </time>
        </a>
      ))
    }
  </div>
</div>
