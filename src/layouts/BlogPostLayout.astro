---
import BaseLayout from "./BaseLayout.astro";
import type { CollectionEntry } from "astro:content";
import ReadingProgress from "../components/ReadingProgress.astro";
import AuthorBio from "../components/AuthorBio.astro";
import RelatedPosts from "../components/RelatedPosts.astro";

interface Props {
  post: CollectionEntry<"blog">;
}

const { post } = Astro.props;
const { title, description, author, pubDate, image, tags, category } = post.data;

// Format date
const formattedDate = pubDate.toLocaleDateString("en-US", {
  year: "numeric",
  month: "long",
  day: "numeric",
});

// Calculate reading time if not provided
const readingTime =
  post.data.readingTime || `${Math.ceil(post.body?.split(/\s+/).length / 200 || 1)} min read`;
---

<BaseLayout
  title={title}
  description={description}
  image={image}
  type="article"
  publishedTime={pubDate}
  author={author}
>
  <ReadingProgress />

  <article class="container-custom py-16 md:py-24">
    <!-- Article Header -->
    <header class="max-w-3xl mx-auto mb-12">
      <!-- Category & Tags -->
      <div class="flex flex-wrap gap-2 mb-4">
        <span
          class="px-3 py-1 text-sm font-medium bg-electric-500/20 text-electric-400 rounded-full"
        >
          {category}
        </span>
        {
          tags.map((tag) => (
            <span class="px-3 py-1 text-sm bg-white/5 text-gray-400 rounded-full">#{tag}</span>
          ))
        }
      </div>

      <!-- Title -->
      <h1 class="text-4xl md:text-5xl lg:text-6xl font-display font-bold mb-6 neon-text">
        {title}
      </h1>

      <!-- Meta -->
      <div class="flex flex-wrap items-center gap-4 text-gray-400">
        <span>By {author}</span>
        <span>·</span>
        <time datetime={pubDate.toISOString()}>{formattedDate}</time>
        <span>·</span>
        <span>{readingTime}</span>
      </div>
    </header>

    <!-- Featured Image -->
    {
      image && (
        <div class="max-w-4xl mx-auto mb-12">
          <div class="aspect-video rounded-2xl overflow-hidden glass-card">
            <img
              src={image}
              alt={post.data.imageAlt || title}
              class="w-full h-full object-cover"
              loading="eager"
            />
          </div>
        </div>
      )
    }

    <!-- Article Content -->
    <div
      class="max-w-3xl mx-auto prose prose-invert prose-lg prose-headings:font-display prose-headings:text-white prose-a:text-electric-400 hover:prose-a:text-electric-300 prose-code:text-electric-400"
    >
      <slot />
    </div>

    <!-- Author Bio -->
    <div class="max-w-3xl mx-auto mt-16">
      <AuthorBio author={author} />
    </div>

    <!-- Related Posts -->
    <div class="mt-16">
      <RelatedPosts currentPost={post} />
    </div>
  </article>
</BaseLayout>
